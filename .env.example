# Daft Examples - Environment Variables
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env

# ============================================================================
# Required for Quickstart Examples (01-05)
# ============================================================================

# OpenAI API Key (required for most examples)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-

# ============================================================================
# Optional for Quickstart Examples
# ============================================================================

# Turbopuffer API Key (optional - for vector search in quickstart/02)
# Get yours at: https://turbopuffer.com
# If not set, quickstart/02 will skip the database write step
TURBOPUFFER_API_KEY=

# ============================================================================
# Optional for Advanced Examples
# ============================================================================

# OpenRouter API Key (for multi-model access)
# Get yours at: https://openrouter.ai/keys
# Used in: patterns/prompt/prompt_session.py, use_cases/ai_visibility_tracking.py
OPENROUTER_API_KEY=sk-or-v1-

# HuggingFace Token (for private datasets)
# Get yours at: https://huggingface.co/settings/tokens
# Most examples use public datasets and don't need this
HF_TOKEN=

# AWS Credentials (for S3 data ingestion examples)
# Used in: use_cases/social_recommendation/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Databricks Unity Catalog (for UC integration examples)
# Used in: use_cases/social_recommendation/write_index_to_uc.py
UC_TABLE_NAME=

# ============================================================================
# Quick Start Guide
# ============================================================================
#
# For hackathon participants - minimum viable setup:
#   1. Copy this file: cp .env.example .env
#   2. Add your OpenAI API key
#   3. Run: uv run quickstart/01_hello_world_prompt.py
#
# That's it! Other API keys are optional and only needed for specific examples.
#
# ============================================================================
